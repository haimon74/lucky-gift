{
  "expo": {
    "name": "Lucky Gift",
    "slug": "lucky-gift",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0a0a0f",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "us.haimazar.luckygift"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "us.haimazar.luckygift"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "luckygift",
    "extra": {
      "apiUrl": "https://luck-gift.haimazar.us"
    }
  }
}
